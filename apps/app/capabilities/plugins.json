{
	"identifier": "plugins",
	"description": "",
	"local": true,
	"windows": ["main"],
	"permissions": [
		"dialog:allow-open",
		"dialog:allow-confirm",
		"opener:default",
		"os:allow-platform",
		"os:allow-version",
		"os:allow-os-type",
		"os:allow-family",
		"os:allow-arch",
		"os:allow-exe-extension",
		"os:allow-locale",
		"os:allow-hostname",
		"deep-link:default",
		"window-state:default",
		"window-state:allow-restore-state",
		"window-state:allow-save-window-state",
		{
			"identifier": "http:default",
			"allow": [
				{
					"url": "https://modrinth.com/*"
				},
				{
					"url": "https://*.modrinth.com/*"
				},
				{
					"url": "https://api.curseforge.com/*"
				},
				{
					"url": "https://edge.forgecdn.net/*"
				},
				{
					"url": "https://media.forgecdn.net/*"
				},
				{
					"url": "https://cdn.curseforge.com/*"
				},
				{
					"url": "https://kerberos.curseforge.com/*"
				},
				{
					"url": "https://*.curseforge.com/*"
				}
			]
		},
		"auth:default",
		"import:default",
		"jre:default",
		"logs:default",
		"metadata:default",
		"minecraft-skins:default",
		"mr-auth:default",
		"profile-create:default",
		"pack:default",
		"process:default",
		"profile:default",
		"cache:default",
		"settings:default",
		"syncing:default",
		"tags:default",
		"utils:default",
		"friends:default",
		"worlds:default"
	]
}
